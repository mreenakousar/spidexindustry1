iv>\n              <div class=\"serial\" style=\"text-align:center;margin-bottom:8px\" data-kid=\"249\">NO. WJ-006 · 16oz WAXED</div>\n              <div class=\"product-photo-wrap\" data-kid=\"250\">\n                <img src=\"https://kombai-assets.b-cdn.net/generated_assets/a6a3f100-283a-4cf8-9be9-44c4db7bb4be/46900675a5104620a64775e37b4108ac.png\" alt=\"Work Jacket WJ-006 in Waxed Rust\" loading=\"lazy\" onerror=\"this.style.display='none'\" data-kid=\"251\">\n              </div>\n              <div class=\"product-name-block\" data-kid=\"252\">\n                <div class=\"product-name\" data-kid=\"253\">WORK JACKET</div>\n                <div class=\"product-variant\" data-kid=\"254\">WAXED RUST · BLANKET-LINED</div>\n                <div class=\"product-price-row\" data-kid=\"255\">\n                  <span class=\"product-price\" data-kid=\"256\">$326</span>\n                  <span class=\"product-flip-hint\" data-kid=\"257\">FLIP FOR SPECS ↻</span>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div class=\"flip-back\" style=\"position:absolute;inset:0\" data-kid=\"258\">\n            <div class=\"spec-back hangtag-shape kraft-tex paper-shadow\" style=\"height:100%\" data-kid=\"259\">\n              <div class=\"hangtag-hole\" aria-hidden=\"true\" data-kid=\"260\"></div>\n              <div class=\"spec-title\" data-kid=\"261\">WJ-006 · SPEC SHEET</div>\n              <div class=\"stitch-border\" data-kid=\"262\"></div>\n              <table class=\"spec-table\" data-kid=\"263\">\n                <tr data-kid=\"264\"><td data-kid=\"265\">Shell</td><td data-kid=\"266\">16oz waxed sailcloth</td></tr>\n                <tr data-kid=\"267\"><td data-kid=\"268\">Mill</td><td data-kid=\"269\">Fairfield Textile, NJ</td></tr>\n                <tr data-kid=\"270\"><td data-kid=\"271\">Lining</td><td data-kid=\"272\">Pendleton wool plaid</td></tr>\n                <tr data-kid=\"273\"><td data-kid=\"274\">Thread</td><td data-kid=\"275\">Tex-90 bonded nylon</td></tr>\n                <tr data-kid=\"276\"><td data-kid=\"277\">SPI</td><td data-kid=\"278\">7 stitches/in</td></tr>\n                <tr data-kid=\"279\"><td data-kid=\"280\">Bartacks</td><td data-kid=\"281\">22 (pockets, cuffs)</td></tr>\n                <tr data-kid=\"282\"><td data-kid=\"283\">Hardware</td><td data-kid=\"284\">Antique brass snaps</td></tr>\n                <tr data-kid=\"285\"><td data-kid=\"286\">Pockets</td><td data-kid=\"287\">4 ext · 2 int chest</td></tr>\n                <tr data-kid=\"288\"><td data-kid=\"289\">Care</td><td data-kid=\"290\">Re-wax annually</td></tr>\n              </table>\n              <a href=\"#\" class=\"stamp\" style=\"color:var(--indigo);border-color:var(--indigo);text-align:center;margin-top:12px;display:block\" data-kid=\"291\">ADD TO CART</a>\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"collection-cta-row\" data-kid=\"292\">\n      <a href=\"#\" class=\"btn-stamp\" style=\"color:var(--cream);border-color:var(--brass)\" data-kid=\"293\">VIEW ALL 14 PIECES →</a>\n    </div>\n\n  </div>\n</section>\n\n\n<section id=\"wages\" class=\"section-wages\" aria-labelledby=\"wages-h2\" data-kid=\"294\">\n\n  \n  <div class=\"wages-layer-base\" data-kid=\"295\">\n    <img src=\"https://kombai-assets.b-cdn.net/generated_assets/a6a3f100-283a-4cf8-9be9-44c4db7bb4be/7cab8cc2c2ae40a4945cc9b8f4f2f86e.png\" alt aria-hidden=\"true\" loading=\"lazy\" onerror=\"this.style.display='none'\" data-kid=\"296\">\n    <div class=\"wages-base-overlay\" aria-hidden=\"true\" data-kid=\"297\"></div>\n  </div>\n\n  \n  <div class=\"wages-layer-reveal\" aria-hidden=\"true\" data-kid=\"298\">\n    <img src=\"https://kombai-assets.b-cdn.net/generated_assets/a6a3f100-283a-4cf8-9be9-44c4db7bb4be/7cab8cc2c2ae40a4945cc9b8f4f2f86e.png\" alt loading=\"lazy\" onerror=\"this.style.display='none'\" data-kid=\"299\">\n    <div class=\"wages-reveal-overlay\" data-kid=\"300\"></div>\n  </div>\n\n  \n  <div class=\"wages-content\" data-kid=\"301\">\n    <span class=\"wages-eyebrow\" data-kid=\"302\">— FILED Q3 2024 · METHODOLOGY OPEN —</span>\n    <h2 class=\"wages-h2\" id=\"wages-h2\" data-kid=\"303\">WHAT WE PAY,<br data-kid=\"304\">OUT LOUD.</h2>\n\n    <div class=\"wages-tag\" data-kid=\"305\">\n      <div class=\"wages-tag-twine twine-line\" aria-hidden=\"true\" data-kid=\"306\"></div>\n      <div class=\"wages-tag-hole\" aria-hidden=\"true\" data-kid=\"307\"></div>\n\n      <div class=\"wages-avg-label\" data-kid=\"308\">AVERAGE HOURLY WAGE · ALL FLOOR STAFF</div>\n      <span class=\"wages-big-number shine-text\" aria-label=\"$28.40\" data-kid=\"309\">$28.40</span>\n      <div class=\"wages-benefits\" data-kid=\"310\">+ FULL HEALTH · + PENSION · + 19 PAID DAYS</div>\n\n      <div class=\"wages-stats-row\" data-kid=\"311\">\n        <div class=\"wages-stat\" data-kid=\"312\">\n          <div class=\"wages-stat-label\" data-kid=\"313\">LOWEST WAGE</div>\n          <div class=\"wages-stat-num\" data-kid=\"314\">$22.10</div>\n          <div class=\"wages-stat-desc\" data-kid=\"315\">Apprentice, station 02. Floor min. 2.8× Wisconsin minimum.</div>\n        </div>\n        <div class=\"wages-stat\" data-kid=\"316\">\n          <div class=\"wages-stat-label\" data-kid=\"317\">MEDIAN WAGE</div>\n          <div class=\"wages-stat-num\" data-kid=\"318\">$27.95</div>\n          <div class=\"wages-stat-desc\" data-kid=\"319\">11-year journeyworker. Ratio to founder pay: 1 : 4.2.</div>\n        </div>\n        <div class=\"wages-stat\" data-kid=\"320\">\n          <div class=\"wages-stat-label\" data-kid=\"321\">HIGHEST WAGE</div>\n          <div class=\"wages-stat-num\" data-kid=\"322\">$36.80</div>\n          <div class=\"wages-stat-desc\" data-kid=\"323\">Master cutter, 34 yrs. CBA scale + skill premium.</div>\n        </div>\n      </div>\n\n      <div class=\"wages-methodology\" data-kid=\"324\">\n        <p data-kid=\"325\">Wages reported are gross hourly, averaged across 47 production employees over 13 pay periods (Apr–Sep 2024). Excludes 3 owner-operators and 4 administrative roles.</p>\n        <p data-kid=\"326\">Of every $198 pair of jeans sold, <strong style=\"color:var(--brass)\" data-kid=\"327\">$31.40</strong> goes directly to floor labor. Materials: $42. Overhead &amp; repair: $48. Margin: 12%. <a href=\"#\" data-kid=\"328\">Full breakdown ↗</a></p>\n      </div>\n\n      <div class=\"stamp wages-verified-stamp\" style=\"position:relative;margin-top:20px;align-self:flex-end;display:inline-block\" data-kid=\"329\">VERIFIED · LOCAL 119</div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"size\" class=\"section-size\" aria-labelledby=\"size-h2\" data-kid=\"330\">\n  <div class=\"inner\" data-kid=\"331\">\n\n    <div class=\"size-head\" data-kid=\"332\">\n      <span class=\"size-eyebrow\" data-kid=\"333\">— FLAT-MEASURE GUIDE · INCHES —</span>\n      <div class=\"size-h2\" data-kid=\"334\">\n        <span class=\"size-h2-inner\" id=\"size-h2\" data-kid=\"335\">FIND YOUR FIT.</span>\n      </div>\n    </div>\n\n    <div class=\"size-layout\" data-kid=\"336\">\n\n      \n      <div class=\"diagram-card paper-shadow\" data-kid=\"337\">\n        <span class=\"diagram-label\" data-kid=\"338\">FIG. 01 · MEASUREMENT POINTS</span>\n        <svg viewBox=\"0 0 240 360\" class=\"diagram-svg\" stroke=\"var(--indigo)\" fill=\"none\" stroke-width=\"1.5\" role=\"img\" aria-label=\"Garment measurement diagram\" data-kid=\"339\">\n          \n          <path class=\"draw-path\" d=\"M40,30 L200,30 L196,60 L44,60 Z\" stroke-width=\"2\" fill=\"none\" data-kid=\"340\"></path>\n          <path class=\"draw-path\" d=\"M44,60 L40,340 L110,340 L120,140 L130,340 L200,340 L196,60\" fill=\"none\" data-kid=\"341\"></path>\n          \n          <line class=\"draw-path\" x1=\"120\" y1=\"60\" x2=\"120\" y2=\"140\" stroke-dasharray=\"3 3\" stroke=\"var(--indigo)\" data-kid=\"342\"></line>\n          \n          <g stroke=\"var(--brass)\" stroke-width=\"1.2\" data-kid=\"343\">\n            <line class=\"draw-path-fast\" x1=\"20\" y1=\"45\" x2=\"220\" y2=\"45\" stroke-dasharray=\"2 2\" data-kid=\"344\"></line>\n            <line class=\"draw-path-fast\" x1=\"10\" y1=\"100\" x2=\"60\" y2=\"100\" stroke-dasharray=\"2 2\" data-kid=\"345\"></line>\n            <line class=\"draw-path-fast\" x1=\"10\" y1=\"220\" x2=\"50\" y2=\"220\" stroke-dasharray=\"2 2\" data-kid=\"346\"></line>\n            <line class=\"draw-path-fast\" x1=\"40\" y1=\"340\" x2=\"40\" y2=\"355\" data-kid=\"347\"></line>\n            <line class=\"draw-path-fast\" x1=\"110\" y1=\"340\" x2=\"110\" y2=\"355\" data-kid=\"348\"></line>\n            <line class=\"draw-path-fast\" x1=\"40\" y1=\"355\" x2=\"110\" y2=\"355\" data-kid=\"349\"></line>\n            <line class=\"draw-path-fast\" x1=\"210\" y1=\"140\" x2=\"210\" y2=\"335\" stroke-dasharray=\"2 2\" data-kid=\"350\"></line>\n          </g>\n          \n          <g font-family=\"JetBrains Mono\" font-size=\"8\" fill=\"var(--twine)\" data-kid=\"351\">\n            <text x=\"0\" y=\"42\" data-kid=\"352\">A · WAIST</text>\n            <text x=\"0\" y=\"97\" data-kid=\"353\">B · THIGH</text>\n            <text x=\"0\" y=\"217\" data-kid=\"354\">C · KNEE</text>\n            <text x=\"0\" y=\"354\" data-kid=\"355\">D · LEG OPEN.</text>\n            <text x=\"208\" y=\"240\" transform=\"rotate(90 208 240)\" data-kid=\"356\">E · INSEAM</text>\n          </g>\n        </svg>\n        <p class=\"diagram-note\" data-kid=\"357\">Lay garment flat. Measure across — do not double. Round to nearest ¼ inch. Compare to your favorite pair.</p>\n      </div>\n\n      \n      <div class=\"size-table-card paper-shadow\" data-kid=\"358\">\n        <div class=\"size-table-header\" data-kid=\"359\">\n          <span class=\"size-table-title\" data-kid=\"360\">DUNGAREE 01 · STRAIGHT</span>\n          <span class=\"size-table-rev\" data-kid=\"361\">REV. 2024.09 · INCHES</span>\n        </div>\n        <table class=\"size-table\" id=\"sizeTable\" data-kid=\"362\">\n          <thead data-kid=\"363\">\n            <tr data-kid=\"364\">\n              <th data-kid=\"365\">SIZE</th>\n              <th data-kid=\"366\">A · WAIST</th>\n              <th data-kid=\"367\">B · THIGH</th>\n              <th data-kid=\"368\">C · KNEE</th>\n              <th data-kid=\"369\">D · OPENING</th>\n              <th data-kid=\"370\">E · INSEAM</th>\n              <th style=\"text-align:right\" data-kid=\"371\">STOCK</th>\n            </tr>\n          </thead>\n          <tbody data-kid=\"372\">\n            <tr class=\"size-row\" data-kid=\"373\"><td data-kid=\"374\">28</td><td data-kid=\"375\">28.0</td><td data-kid=\"376\">11.4</td><td data-kid=\"377\">8.6</td><td data-kid=\"378\">7.8</td><td data-kid=\"379\">32.0</td><td style=\"color:var(--brass)\" data-kid=\"380\">● 4 LEFT</td></tr>\n            <tr class=\"size-row active\" data-kid=\"381\"><td data-kid=\"382\">30</td><td data-kid=\"383\">30.0</td><td data-kid=\"384\">11.8</td><td data-kid=\"385\">8.9</td><td data-kid=\"386\">8.0</td><td data-kid=\"387\">32.0</td><td style=\"color:var(--indigo)\" data-kid=\"388\">● IN STOCK</td></tr>\n            <tr class=\"size-row\" data-kid=\"389\"><td data-kid=\"390\">32</td><td data-kid=\"391\">32.0</td><td data-kid=\"392\">12.2</td><td data-kid=\"393\">9.1</td><td data-kid=\"394\">8.2</td><td data-kid=\"395\">32.0</td><td style=\"color:var(--indigo)\" data-kid=\"396\">● IN STOCK</td></tr>\n            <tr class=\"size-row\" data-kid=\"397\"><td data-kid=\"398\">34</td><td data-kid=\"399\">34.0</td><td data-kid=\"400\">12.6</td><td data-kid=\"401\">9.4</td><td data-kid=\"402\">8.4</td><td data-kid=\"403\">34.0</td><td style=\"color:var(--indigo)\" data-kid=\"404\">● IN STOCK</td></tr>\n            <tr class=\"size-row\" data-kid=\"405\"><td data-kid=\"406\">36</td><td data-kid=\"407\">36.0</td><td data-kid=\"408\">13.1</td><td data-kid=\"409\">9.7</td><td data-kid=\"410\">8.6</td><td data-kid=\"411\">34.0</td><td style=\"color:var(--brass)\" data-kid=\"412\">● 7 LEFT</td></tr>\n            <tr class=\"size-row\" data-kid=\"413\"><td data-kid=\"414\">38</td><td data-kid=\"415\">38.0</td><td data-kid=\"416\">13.5</td><td data-kid=\"417\">10.0</td><td data-kid=\"418\">8.8</td><td data-kid=\"419\">34.0</td><td style=\"color:rgba(106,74,48,.6)\" data-kid=\"420\">○ RESTOCK 11/14</td></tr>\n            <tr class=\"size-row\" data-kid=\"421\"><td data-kid=\"422\">40</td><td data-kid=\"423\">40.0</td><td data-kid=\"424\">14.0</td><td data-kid=\"425\">10.3</td><td data-kid=\"426\">9.0</td><td data-kid=\"427\">36.0</td><td style=\"color:var(--indigo)\" data-kid=\"428\">● IN STOCK</td></tr>\n          </tbody>\n        </table>\n        <div class=\"size-table-footer\" data-kid=\"429\">\n          <span data-kid=\"430\">RAW SHRINKAGE: 3% LENGTH · 1.5% WAIST</span>\n          <span data-kid=\"431\">SANFORIZED · MIN. POST-WASH MOVEMENT</span>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"site-footer denim-tex\" role=\"contentinfo\" data-kid=\"432\">\n  <div class=\"footer-inner\" data-kid=\"433\">\n\n    \n    <div class=\"crate-label\" data-kid=\"434\">\n      <div data-kid=\"435\">\n        <div class=\"crate-from-label\" data-kid=\"436\">SHIP FROM / ORIGIN</div>\n        <div class=\"crate-brand\" data-kid=\"437\">FOREMAN &amp; FORGE CO.</div>\n        <div class=\"crate-address\" data-kid=\"438\">412 W. RAILROAD AVE · WAUKESHA, WI 53186</div>\n      </div>\n      <div class=\"crate-barcode-area\" data-kid=\"439\">\n        <div class=\"barcode\" style=\"width:220px\" data-kid=\"440\"></div>\n        <div class=\"crate-barcode-num\" data-kid=\"441\">FF-2024-W11-0047 · NET 14oz · LOT A</div>\n      </div>\n    </div>\n\n    \n    <div class=\"footer-grid\" data-kid=\"442\">\n\n      \n      <div data-kid=\"443\">\n        <div class=\"footer-about-brand\" data-kid=\"444\">UNION MADE.<br data-kid=\"445\">BY NAME.</div>\n        <p class=\"footer-about-body\" data-kid=\"446\">A 47-person factory in Wisconsin sewing heavy workwear with published wages, repairable seams, and zero retail markup.</p>\n        <div class=\"footer-union-bug\" data-kid=\"447\">\n          <div class=\"rivet\" style=\"width:32px;height:32px;flex-shrink:0\" aria-hidden=\"true\" data-kid=\"448\"></div>\n          <div data-kid=\"449\">\n            <div class=\"footer-union-label\" data-kid=\"450\">UNION BUG</div>\n            <div class=\"footer-union-afl\" data-kid=\"451\">AFL · LOCAL 119</div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"footer-col\" data-kid=\"452\">\n        <span class=\"footer-col-heading\" data-kid=\"453\">SHOP</span>\n        <ul data-kid=\"454\">\n          <li data-kid=\"455\">Dungarees</li>\n          <li data-kid=\"456\">Chore Coats</li>\n          <li data-kid=\"457\">Work Jackets</li>\n          <li data-kid=\"458\">Shop Shirts</li>\n          <li data-kid=\"459\">Aprons &amp; Accessories</li>\n          <li data-kid=\"460\">Last Pairs</li>\n        </ul>\n      </div>\n\n      \n      <div class=\"footer-col\" data-kid=\"461\">\n        <span class=\"footer-col-heading\" data-kid=\"462\">FACTORY</span>\n        <ul data-kid=\"463\">\n          <li data-kid=\"464\">The 47 Makers</li>\n          <li data-kid=\"465\">Wage Methodology</li>\n          <li data-kid=\"466\">Mill Sourcing</li>\n          <li data-kid=\"467\">Repairs for Life</li>\n          <li data-kid=\"468\">Tours &amp; Visits</li>\n          <li data-kid=\"469\">Apprenticeship</li>\n        </ul>\n      </div>\n\n      \n      <div class=\"footer-col\" data-kid=\"470\">\n        <span class=\"footer-col-heading\" data-kid=\"471\">SERVICE</span>\n        <ul data-kid=\"472\">\n          <li data-kid=\"473\">Size Guide</li>\n          <li data-kid=\"474\">Shipping</li>\n          <li data-kid=\"475\">Returns (30 days)</li>\n          <li data-kid=\"476\">Hemming Service</li>\n          <li data-kid=\"477\">Patch &amp; Mend Kit</li>\n          <li data-kid=\"478\">Contact: 414-555-0119</li>\n        </ul>\n      </div>\n\n      \n      <div class=\"footer-col\" data-kid=\"479\">\n        <span class=\"footer-col-heading\" data-kid=\"480\">DISPATCH</span>\n        <p class=\"footer-dispatch-body\" data-kid=\"481\">Monthly letter from the floor. Wage updates, new drops, repair tips. No bullshit.</p>\n        <form class=\"footer-dispatch-form\" onsubmit=\"return false\" data-kid=\"482\">\n          <input type=\"email\" placeholder=\"you@workshop.com\" aria-label=\"Email address\" data-kid=\"483\">\n          <button type=\"submit\" data-kid=\"484\">JOIN →</button>\n        </form>\n      </div>\n\n    </div>\n\n    <div class=\"footer-bottom\" data-kid=\"485\">\n      <div data-kid=\"486\">© 1947–2024 FOREMAN &amp; FORGE CO. · ALL RIGHTS RESERVED · MADE IN U.S.A.</div>\n      <div class=\"footer-legal-links\" data-kid=\"487\">\n        <span data-kid=\"488\">PRIVACY</span>\n        <span data-kid=\"489\">TERMS</span>\n        <span data-kid=\"490\">ACCESSIBILITY</span>\n        <span data-kid=\"491\">CA SUPPLY CHAIN ACT</span>\n      </div>\n    </div>\n\n  </div>\n</footer>\n\n<script data-kid=\"492\">\n// ===== ONE rAF SCROLL LOOP =====\n// Drives: hero parallax layers, #23 word-mask-fill progress, #29 spotlight\n(function() {\n  'use strict';\n\n  var scrollY = 0, lastScrollY = 0, ticking = false;\n  var mouseX = 0, mouseY = 0, mouseTicking = false;\n\n  // ---- Element refs ----\n  var hero = document.querySelector('.hero');\n  var heroLayers = [];\n  var builtSection = document.querySelector('.section-builthere');\n  var builtH2Words = document.querySelectorAll('.builthere-h2 .word');\n  var wagesSection = document.querySelector('.section-wages');\n  var wagesH2 = document.querySelector('.wages-h2');\n  var collectionH2 = document.querySelector('.collection-h2');\n\n  // Build hero layer list from data-depth attributes\n  (function buildHeroLayers() {\n    var layers = document.querySelectorAll('.hero-layer');\n    layers.forEach(function(el) {\n      var depth = parseFloat(el.style.getPropertyValue('--depth') || 0);\n      heroLayers.push({ el: el, depth: depth });\n    });\n  })();\n\n  // ---- rAF scroll update ----\n  function update() {\n    ticking = false;\n    var sy = scrollY;\n\n    // Hero parallax: translate each layer by scrollY * depth\n    var heroH = hero ? hero.offsetHeight : window.innerHeight;\n    var heroProgress = Math.max(0, Math.min(1, sy / heroH));\n    heroLayers.forEach(function(layer) {\n      var shift = sy * layer.depth;\n      layer.el.style.transform = 'translate3d(0,' + shift + 'px,0)';\n    });\n\n    // #23 word-mask-image-fill\n    if (builtSection && builtH2Words.length > 0) {\n      var rect = builtSection.getBoundingClientRect();\n      var sectionTop = rect.top + sy;\n      var sectionH = builtSection.offsetHeight;\n      var prog = Math.max(0, Math.min(1, (sy - sectionTop + window.innerHeight * 0.5) / (sectionH * 0.7)));\n      // Word 0: fills 0→0.25; Word 1: fills 0.25→0.55; Word 2: fills 0.55→0.85\n      var thresholds = [0, 0.25, 0.55];\n      builtH2Words.forEach(function(word, i) {\n        var t = thresholds[i];\n        var next = (i < thresholds.length - 1) ? thresholds[i+1] : 0.85;\n        var wordProg = Math.max(0, Math.min(1, (prog - t) / (next - t)));\n        if (wordProg >= 0.5) {\n          word.classList.add('filled');\n        } else {\n          word.classList.remove('filled');\n        }\n      });\n    }\n  }\n\n  window.addEventListener('scroll', function() {\n    scrollY = window.scrollY;\n    if (!ticking) {\n      requestAnimationFrame(update);\n      ticking = true;\n    }\n  }, { passive: true });\n\n  // Initial call\n  update();\n\n  // ---- #29 spotlight — mousemove on wages section ----\n  if (wagesSection) {\n    wagesSection.addEventListener('mousemove', function(e) {\n      var rect = wagesSection.getBoundingClientRect();\n      mouseX = e.clientX - rect.left;\n      mouseY = e.clientY - rect.top;\n      if (!mouseTicking) {\n        requestAnimationFrame(function() {\n          wagesSection.style.setProperty('--mx', mouseX + 'px');\n          wagesSection.style.setProperty('--my', mouseY + 'px');\n          mouseTicking = false;\n        });\n        mouseTicking = true;\n      }\n    });\n    // Reset to center on leave\n    wagesSection.addEventListener('mouseleave', function() {\n      var r = wagesSection.getBoundingClientRect();\n      wagesSection.style.setProperty('--mx', (r.width / 2) + 'px');\n      wagesSection.style.setProperty('--my', (r.height / 2) + 'px');\n    });\n  }\n\n  // ---- IntersectionObserver: section entrance animations ----\n  var io = new IntersectionObserver(function(entries) {\n    entries.forEach(function(entry) {\n      if (entry.isIntersecting) {\n        var el = entry.target;\n        // Small delay to let scroll settle\n        var delay = parseInt(el.dataset.delay || 0);\n        setTimeout(function() { el.classList.add('in-view'); }, delay);\n        io.unobserve(el);\n      }\n    });\n  }, { threshold: 0.12 });\n\n  // Sections\n  document.querySelectorAll('.section-builthere, .section-collection, .section-wages, .section-size, .site-footer, .section-divider').forEach(function(el) {\n    io.observe(el);\n  });\n\n  // ---- Worker card cascade (IntersectionObserver on section) ----\n  var workerIO = new IntersectionObserver(function(entries) {\n    entries.forEach(function(entry) {\n      if (entry.isIntersecting) {\n        var cols = document.querySelectorAll('.worker-col');\n        cols.forEach(function(col, i) {\n          setTimeout(function() { col.classList.add('in-view'); }, i * 120);\n        });\n        workerIO.unobserve(entry.target);\n      }\n    });\n  }, { threshold: 0.1 });\n  if (builtSection) workerIO.observe(builtSection);\n\n  // ---- Flip cards (bento) — cascade rise ----\n  var flipIO = new IntersectionObserver(function(entries) {\n    entries.forEach(function(entry) {\n      if (entry.isIntersecting) {\n        var cards = document.querySelectorAll('.flip-card');\n        cards.forEach(function(card, i) {\n          setTimeout(function() { card.classList.add('in-view'); }, i * 110);\n        });\n        flipIO.unobserve(entry.target);\n      }\n    });\n  }, { threshold: 0.08 });\n  var collectSection = document.querySelector('.section-collection');\n  if (collectSection) flipIO.observe(collectSection);\n\n  // ---- Collection h2 clip-path wipe ----\n  if (collectionH2) {\n    // Set clip-ready only after JS confirms the element exists\n    collectionH2.classList.add('clip-ready');\n    var colIO = new IntersectionObserver(function(entries) {\n      if (entries[0].isIntersecting) {\n        // Small rAF to ensure clip-ready transition fires correctly\n        requestAnimationFrame(function() {\n          setTimeout(function() { collectionH2.classList.add('is-revealed'); }, 80);\n        });\n        colIO.unobserve(entries[0].target);\n      }\n    }, { threshold: 0.15 });\n    colIO.observe(collectionH2);\n  }\n\n  // ---- Wages h2 letter-spacing wind-up ----\n  if (wagesH2) {\n    var wIO = new IntersectionObserver(function(entries) {\n      if (entries[0].isIntersecting) {\n        setTimeout(function() { wagesH2.classList.add('is-revealed'); }, 200);\n        wIO.unobserve(entries[0].target);\n      }\n    }, { threshold: 0.3 });\n    wIO.observe(wagesH2);\n  }\n\n  // ---- Bento-grid hover-expand sibling dim ----\n  document.querySelectorAll('.flip-card').forEach(function(card) {\n    card.addEventListener('mouseenter', function() {\n      document.querySelectorAll('.flip-card').forEach(function(c) {\n        if (c !== card) c.classList.add('sibling-dim');\n        else c.classList.remove('sibling-dim');\n      });\n    });\n    card.addEventListener('mouseleave', function() {\n      document.querySelectorAll('.flip-card').forEach(function(c) {\n        c.classList.remove('sibling-dim');\n      });\n    });\n    // Click to flip\n    card.addEventListener('click', function() {\n      card.classList.toggle('is-flipped');\n    });\n  });\n\n  // ---- Hero clip-path wipe entrance on load ----\n  window.addEventListener('DOMContentLoaded', function() {\n    setTimeout(function() {\n      document.querySelectorAll('.wipe-inner').forEach(function(span) {\n        span.classList.add('is-revealed');\n      });\n    }, 400);\n  });\n  // Fallback if DOMContentLoaded already fired\n  if (document.readyState === 'complete' || document.readyState === 'interactive') {\n    setTimeout(function() {\n      document.querySelectorAll('.wipe-inner').forEach(function(span) {\n        span.classList.add('is-revealed');\n      });\n    }, 400);\n  }\n\n  // ---- Size table row click ----\n  document.querySelectorAll('.size-row').forEach(function(row) {\n    row.addEventListener('click', function() {\n      document.querySelectorAll('.size-row').forEach(function(r) { r.classList.remove('active'); });\n      row.classList.add('active');\n    });\n  });\n\n  // ---- Size guide SVG path-draw on section enter ----\n  var diagramSvg = document.querySelector('.diagram-svg');\n  if (diagramSvg) {\n    var svgIO = new IntersectionObserver(function(entries) {\n      if (entries[0].isIntersecting) {\n        diagramSvg.classList.add('drawing');\n        svgIO.unobserve(entries[0].target);\n      }\n    }, { threshold: 0.3 });\n    svgIO.observe(diagramSvg);\n  }\n\n  // ---- Size h2 slide-up ----\n  var sizeH2Inner = document.querySelector('.size-h2-inner');\n  if (sizeH2Inner) {\n    var sizeIO = new IntersectionObserver(function(entries) {\n      if (entries[0].isIntersecting) {\n        setTimeout(function() { sizeH2Inner.classList.add('is-up'); }, 100);\n        sizeIO.unobserve(entries[0].target);\n      }\n    }, { threshold: 0.4 });\n    sizeIO.observe(sizeH2Inner.parentElement);\n  }\n\n})();\n</script>\n\n",
